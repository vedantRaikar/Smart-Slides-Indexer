  {
    "slide_number": 2,
    "slide_id": "ab0ca7bc-02d1-4717-9c63-19fb028192f8",
    "title": "What is Coupling?",
    "bullets": [
      {
        "text": "What is Coupling?",
        "level": 0
      },
      {
        "text": "\u2022 Coupling indicates the degree of interdependence between two modules.",
        "level": 0
      },
      {
        "text": "\u2022 High coupling means modules are heavily interdependent.",
        "level": 0
      },
      {
        "text": "\u2022 Determined by interface complexity:",
        "level": 0
      },
      {
        "text": "   \u2013 Number of parameters passed",
        "level": 0
      },
      {
        "text": "   \u2013 Complexity of parameters",
        "level": 0
      },
      {
        "text": "\u2022 High coupling \u2192 harder to understand, maintain, and develop independently.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 3,
    "slide_id": "db5577d5-b34f-4e18-94eb-7d601e7f09dd",
    "title": "",
    "bullets": [],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 4,
    "slide_id": "7f7c1e68-3aa7-46dd-848b-7227634527ee",
    "title": "Data Coupling",
    "bullets": [
      {
        "text": "Data Coupling",
        "level": 0
      },
      {
        "text": "\u2022 Two modules communicate by passing elementary data items (int, float, char).",
        "level": 0
      },
      {
        "text": "\u2022 Data must be problem-related, not control-related.",
        "level": 0
      },
      {
        "text": "\u2022 Example: A function passing an integer value as a parameter.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 5,
    "slide_id": "d411bd26-1703-4301-8df8-e8aa0ff0be3e",
    "title": "Stamp Coupling",
    "bullets": [
      {
        "text": "Stamp Coupling",
        "level": 0
      },
      {
        "text": "\u2022 Two modules communicate using composite data items.",
        "level": 0
      },
      {
        "text": "\u2022 Example: Records (Pascal) or Structures (C).",
        "level": 0
      },
      {
        "text": "\u2022 More complex than data coupling.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 6,
    "slide_id": "5086a1a4-9ebb-4fb2-b05b-e1f69afc5c34",
    "title": "Control Coupling",
    "bullets": [
      {
        "text": "Control Coupling",
        "level": 0
      },
      {
        "text": "\u2022 One module controls the execution of another via passed data.",
        "level": 0
      },
      {
        "text": "\u2022 Example: A flag set in one module and tested in another.",
        "level": 0
      },
      {
        "text": "\u2022 Leads to tighter interdependence.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 7,
    "slide_id": "8ccb985a-51cf-460b-bdfc-1832639a5e67",
    "title": "Common Coupling",
    "bullets": [
      {
        "text": "Common Coupling",
        "level": 0
      },
      {
        "text": "\u2022 Two or more modules share global data.",
        "level": 0
      },
      {
        "text": "\u2022 High risk of unintended side effects.",
        "level": 0
      },
      {
        "text": "\u2022 Makes debugging and maintenance harder.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 8,
    "slide_id": "a4477b7d-b10c-41d9-8906-dd34d269dec8",
    "title": "Content Coupling",
    "bullets": [
      {
        "text": "Content Coupling",
        "level": 0
      },
      {
        "text": "\u2022 One module directly uses or modifies code of another.",
        "level": 0
      },
      {
        "text": "\u2022 Example: Jumps into another module\u2019s code.",
        "level": 0
      },
      {
        "text": "\u2022 Not supported in modern high-level languages (e.g., C).",
        "level": 0
      },
      {
        "text": "\u2022 Highest degree of coupling, most undesirable.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  },
  {
    "slide_number": 9,
    "slide_id": "2f367e88-3ce8-42a9-b342-a924f3b13820",
    "title": "Coupling Severity Order",
    "bullets": [
      {
        "text": "Coupling Severity Order",
        "level": 0
      },
      {
        "text": "\u2022 From least to most severe:",
        "level": 0
      },
      {
        "text": "   1. Data Coupling",
        "level": 0
      },
      {
        "text": "   2. Stamp Coupling",
        "level": 0
      },
      {
        "text": "   3. Control Coupling",
        "level": 0
      },
      {
        "text": "   4. Common Coupling",
        "level": 0
      },
      {
        "text": "   5. Content Coupling",
        "level": 0
      },
      {
        "text": "Higher coupling \u2192 Higher complexity and maintenance cost.",
        "level": 0
      }
    ],
    "images": [],
    "tables": [],
    "notes": ""
  }
]