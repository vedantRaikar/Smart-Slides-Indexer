    "191cfeea-18d4-4b81-bd3a-20b16252663b": {
      "slide_id": "191cfeea-18d4-4b81-bd3a-20b16252663b",
      "slide_number": 5,
      "title": "Stamp Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Two modules communicate using composite data items.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Example: Records (Pascal) or Structures (C).",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 More complex than data coupling.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
