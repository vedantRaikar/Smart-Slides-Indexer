    "9997a284-fb89-4da9-83b1-3a7d7ed255e3": {
      "slide_id": "9997a284-fb89-4da9-83b1-3a7d7ed255e3",
      "slide_number": 4,
      "title": "Data Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Two modules communicate by passing elementary data items (int, float, char).",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Data must be problem-related, not control-related.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Example: A function passing an integer value as a parameter.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
