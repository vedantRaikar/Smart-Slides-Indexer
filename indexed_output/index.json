    "095840ca-c4e2-4feb-b636-1e8cc2b6dc57": {
      "slide_id": "095840ca-c4e2-4feb-b636-1e8cc2b6dc57",
      "slide_number": 7,
      "title": "Common Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Two or more modules share global data.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 High risk of unintended side effects.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Makes debugging and maintenance harder.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
