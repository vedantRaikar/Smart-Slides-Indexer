    "7b2d29a1-4551-4f6c-b91e-606b556d5d79": {
      "slide_id": "7b2d29a1-4551-4f6c-b91e-606b556d5d79",
      "slide_number": 5,
      "title": "Stamp Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Two modules communicate using composite data items.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Example: Records (Pascal) or Structures (C).",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 More complex than data coupling.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
