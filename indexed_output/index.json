    "bec8ac61-0a0c-4fd8-9b3a-ca50f40519b5": {
      "slide_id": "bec8ac61-0a0c-4fd8-9b3a-ca50f40519b5",
      "slide_number": 6,
      "title": "Control Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 One module controls the execution of another via passed data.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Example: A flag set in one module and tested in another.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Leads to tighter interdependence.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
