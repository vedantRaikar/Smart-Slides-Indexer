    "69daa611-26d9-42cb-b9af-103f205da2da": {
      "slide_id": "69daa611-26d9-42cb-b9af-103f205da2da",
      "slide_number": 6,
      "title": "Control Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 One module controls the execution of another via passed data.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Example: A flag set in one module and tested in another.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Leads to tighter interdependence.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
