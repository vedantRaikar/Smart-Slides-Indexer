      ],
      "topics": [],
      "summary": "",
      "learning_objectives": [
        "Define common coupling and recognize its characteristics in software modules.",
        "Identify the risks and potential unintended side effects associated with common coupling.",
        "Explain how common coupling complicates debugging and maintenance processes."
      ],
      "importance_score": 0.5,
      "complexity_score": 0.5,
