    "cbe1a40f-20a1-4a39-82c0-8580c75735b1": {
      "slide_id": "cbe1a40f-20a1-4a39-82c0-8580c75735b1",
      "slide_number": 8,
      "title": "Content Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 One module directly uses or modifies code of another.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 Example: Jumps into another module\u2019s code.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Not supported in modern high-level languages (e.g., C).",
          "level": 0,
          "index": 2,
          "keywords": []
        },
        {
          "text": "\u2022 Highest degree of coupling, most undesirable.",
          "level": 0,
          "index": 3,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
      "section_id": "f143e317-2ec4-4562-9f96-2a1656b97323",
      "keywords": [
