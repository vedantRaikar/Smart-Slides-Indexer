        "debugging",
        "maintenance",
        "high risk",
        "share",
        "side effects"
      ],
      "topics": [],
      "summary": "",
      "learning_objectives": [
        "Define common coupling and recognize its characteristics in software modules.",
        "Explain the risks associated with common coupling, including unintended side effects.",
        "Describe how common coupling complicates debugging and maintenance processes.",
        "Identify strategies to reduce or eliminate common coupling in system design."
      ],
      "importance_score": 0.5,
      "complexity_score": 0.5,
