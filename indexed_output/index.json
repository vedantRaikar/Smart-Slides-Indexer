    "84dc4936-d530-4e5c-80c8-e4b63c59ff77": {
      "slide_id": "84dc4936-d530-4e5c-80c8-e4b63c59ff77",
      "slide_number": 7,
      "title": "Common Coupling",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Two or more modules share global data.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 High risk of unintended side effects.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Makes debugging and maintenance harder.",
          "level": 0,
          "index": 2,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
      "section_id": "f143e317-2ec4-4562-9f96-2a1656b97323",
