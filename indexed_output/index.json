    "5038a7ec-f3e3-4a48-a94d-04c133a86a0a": {
      "slide_id": "5038a7ec-f3e3-4a48-a94d-04c133a86a0a",
      "slide_number": 2,
      "title": "What is Coupling?",
      "subtitle": null,
      "bullets": [
        {
          "text": "\u2022 Coupling indicates the degree of interdependence between two modules.",
          "level": 0,
          "index": 0,
          "keywords": []
        },
        {
          "text": "\u2022 High coupling means modules are heavily interdependent.",
          "level": 0,
          "index": 1,
          "keywords": []
        },
        {
          "text": "\u2022 Determined by interface complexity:",
          "level": 0,
          "index": 2,
          "keywords": []
        },
        {
          "text": "\u2013 Number of parameters passed",
          "level": 0,
          "index": 3,
          "keywords": []
        },
        {
          "text": "\u2013 Complexity of parameters",
          "level": 0,
          "index": 4,
          "keywords": []
        },
        {
          "text": "\u2022 High coupling \u2192 harder to understand, maintain, and develop independently.",
          "level": 0,
          "index": 5,
          "keywords": []
        }
      ],
      "images": [],
      "tables": [],
      "notes": null,
      "layout_type": "Title and Content",
      "section_id": "f0f7fe79-dea5-43d0-b594-b738a09d1307",
      "keywords": [
        "Coupling",
        "interdependence",
        "modules",
        "high coupling",
        "interface complexity",
        "parameters",
        "complexity",
        "understand",
        "maintain",
        "develop"
      ],
      "topics": [],
      "summary": "",
      "learning_objectives": [
        "Define coupling and explain its significance in software design.",
        "Identify the characteristics and consequences of high coupling between modules.",
        "Describe how interface complexity, such as the number and complexity of parameters, determines coupling.",
        "Explain why high coupling makes modules harder to understand, maintain, and develop independently."
      ],
